//  is  power of 2

const isPower=(num)=>{
    if(num==1)return true;
    if(num % 2!=0)return false;
    
    return isPower(num/2);
    
}




// power = 2**i  2 ki power i
console.log(isPower(32))

//  using bitwise operator
const isPowerOfTwo = (n) => {
    if (n <= 0) return false;

    return (n & (n - 1)) === 0;
}

console.log(isPowerOfTwo(32))
