// sort array in Ascending order 


const bubbleSort=(arr)=>{
    for(let i=0;i<arr.length;i++){
        for(let j=1;j<arr.length;j++){
            if(arr[j]<arr[j-1]){
                let temp=arr[j];
                arr[j]=arr[j-1];
                arr[j-1]=temp;
            }
        }
    }
    return arr;
}

const buildIn=(arr)=>{
    return arr.sort((a,b)=>b-a)
}

let arr=[10,20,5,4,3];
let brr=bubbleSort([...arr])
let crr=buildIn([...arr])
console.log(brr);
console.log(crr);

