
function HashtagGenerator( str){
    if(str.length >180 || str.length ==0)return false;
    
    let hassedString="#";
    for(let s of str.trim().split(/\s+/)){
        hassedString+=s[0].toUpperCase()+s.slice(1);
    }
    return hassedString;
}
 let x = prompt("Enter string");




console.log(HashtagGenerator(x));
