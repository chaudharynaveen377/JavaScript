 //write a function findLongestWord that takes a string as input ans returns the 
// longest word in string if there are mutiple word retuns the first one encountered


function findLongestWord() {

    let x = prompt("Enter string");

    let arr = x.trim().split(' ');

    console.log(arr);
    let ans=0;
    arr.forEach((x)=>{
        ans=Math.max(ans,x.length)
    })
    console.log(ans);
}
function findLongestWord1() {

    let x = prompt("Enter string");

   
    let ans=0;
    let string="";
    for(let ch of x.split(' ')){
      if(ans<ch.length){
          ans=ch.length;
          string=ch;
      }
    }
    console.log(ans);
    console.log(string);
}

